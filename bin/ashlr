#!/usr/bin/env node
// Thin shim: delegate to the compiled CLI entrypoint.
// Resolve relative to this file so the symlink in ~/.local/bin works.
import { fileURLToPath, pathToFileURL } from 'node:url';
import { dirname, resolve } from 'node:path';

const here = dirname(fileURLToPath(import.meta.url));
// Use a file:// URL, not a raw path: on Windows `import('C:\\...')` throws
// ERR_UNSUPPORTED_ESM_URL_SCHEME (the drive letter parses as a protocol).
import(pathToFileURL(resolve(here, '../dist/cli/index.js')).href);
