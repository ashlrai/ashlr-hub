{
  "foundry": {
    "allowedBackends": ["builtin", "claude", "codex", "local-coder", "nim", "kimi", "hermes"],

    "models": {
      "claude": "claude-sonnet-5",
      "codex": "gpt-5.5",
      "kimi": "kimi-k2-0711-preview",
      "hermes": "hermes-3-llama-3.1-70b"
    },

    "productionVelocity": {
      "enabled": true,
      "profile": "resource-control",
      "fillQueueToSlots": true,
      "stalePendingTtlHours": 24,
      "maxSlotsPerBackend": 3,
      "localMaxConcurrent": 1,
      "nimMaxConcurrent": 2,
      "kimiMaxConcurrent": 2
    },

    "intelligence": {
      "minProposalYieldRate": 0.2,
      "dispatchYieldWindowHours": 24
    },

    "engines": {
      "nim": {
        "id": "nim",
        "kind": "api-model",
        "tier": "mid",
        "api": {
          "envKey": "NVIDIA_NIM_API_KEY",
          "baseUrlEnv": "NVIDIA_NIM_BASE_URL",
          "defaultBaseUrl": "https://integrate.api.nvidia.com/v1",
          "defaultModel": "meta/llama-3.1-70b-instruct",
          "protocol": "openai"
        },
        "capabilities": ["agent", "edit", "tools"]
      },
      "kimi": {
        "id": "kimi",
        "kind": "api-model",
        "tier": "mid",
        "api": {
          "envKey": "MOONSHOT_API_KEY",
          "baseUrlEnv": "MOONSHOT_BASE_URL",
          "defaultBaseUrl": "https://api.moonshot.ai/v1",
          "defaultModel": "kimi-k2-0711-preview",
          "protocol": "openai"
        },
        "capabilities": ["agent", "edit", "architecture"]
      },
      "opencode": {
        "id": "opencode",
        "kind": "cli-agent",
        "tier": "local",
        "bin": "opencode",
        "bins": ["opencode"],
        "argv": ["run", "$GOAL", { "optModel": ["--model", "$MODEL"] }],
        "capabilities": ["agent", "edit"]
      }
    },

    "mergeAuthority": [
      { "engine": "claude", "model": "claude-sonnet-5" },
      { "engine": "codex",  "model": "gpt-5.5" }
    ],

    "limits": {
      "claude": { "window": "5h", "max": 50 },
      "codex":  { "window": "5h", "max": 50 }
    },

    "fabric": {
      "gateway": true,
      "concurrentDispatch": true,
      "maxSlotsPerBackend": 3,
      "workhorseDispatch": true
    },

    "local": {
      "maxConcurrent": 1
    },

    "nim": {
      "maxConcurrent": 2
    },

    "kimi": {
      "maxConcurrent": 2
    },

    "confinement": {
      "*": {
        "mode": "os",
        "networkEgress": false,
        "onUnsupported": "fallback"
      }
    },

    "autoMerge": {
      "enabled": false,
      "trustBasis": "tier"
    }
  }
}
