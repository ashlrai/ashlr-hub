{
  "name": "@ashlr/hub",
  "version": "3.1.0",
  "description": "Local-first command center for agentic engineers.",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "MIT",
  "author": "Mason Wyatt <mason@evero-consulting.com>",
  "homepage": "https://github.com/ashlrai/ashlr-hub#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashlrai/ashlr-hub.git"
  },
  "bugs": {
    "url": "https://github.com/ashlrai/ashlr-hub/issues"
  },
  "keywords": [
    "cli",
    "agentic",
    "mcp",
    "local-first",
    "raycast",
    "developer-tools",
    "ai"
  ],
  "type": "module",
  "bin": {
    "ashlr": "bin/ashlr"
  },
  "files": [
    "dist",
    "bin",
    "scripts/run-verify-command.mjs",
    "schema",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./core": {
      "types": "./dist/api/core.d.ts",
      "import": "./dist/api/core.js"
    },
    "./types": {
      "types": "./dist/api/types.d.ts",
      "import": "./dist/api/types.js"
    },
    "./plugin": {
      "types": "./dist/api/plugin.d.ts",
      "import": "./dist/api/plugin.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test:ci",
    "prepack": "npm run build",
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs && node scripts/build-identity.mjs",
    "build:binary": "node scripts/build-sea.mjs",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:serial": "vitest run --no-file-parallelism",
    "test:ci": "node scripts/test-ci.mjs",
    "test:invariants": "vitest run test/h*.test.ts --no-file-parallelism",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "3.2.6"
  },
  "overrides": {
    "vite": "6.4.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
