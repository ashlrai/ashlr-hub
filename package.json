{
  "name": "ashlr-hub",
  "version": "0.1.0",
  "description": "Ashlr command center — indexes the Desktop and exposes it via the `ashlr` CLI and a Raycast extension.",
  "type": "module",
  "bin": {
    "ashlr": "bin/ashlr"
  },
  "files": [
    "dist",
    "bin",
    "schema"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^2.0.0"
  }
}
